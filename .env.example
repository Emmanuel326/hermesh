# Hedera Account Credentials
# Get these free at https://portal.hedera.com
HEDERA_ACCOUNT_ID=0.0.xxxxxxx
HEDERA_PRIVATE_KEY=your_private_key_here
HEDERA_NETWORK=testnet

# Hermesh Node Configuration
# Create a topic once and reuse the ID across all nodes
HERMESH_TOPIC_ID=0.0.xxxxxxx
HERMESH_NODE_NAME=my-node-1
HERMESH_NODE_PORT=8080
